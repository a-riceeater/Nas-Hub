{
  "name": "nas-hub-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "next build && tsc -p tsconfig.server.json",
    "start": "NODE_ENV=production node dist/src/server.js",
    "create-admin": "tsx scripts/create-admin.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "better-sqlite3": "^12.2.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.44.5",
    "jose": "^6.1.0",
    "next": "^15.5.2",
    "pino": "^9.9.0",
    "pino-pretty": "^13.1.1",
    "prompts": "^2.4.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "systeminformation": "^5.27.8",
    "ws": "^8.18.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.18.0",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
